# Local override для apps/desktop: используем hoisted node_modules вместо
# isolated-symlinks. Иначе electron-builder при packaging-е следует за
# symlink'ом на packages/shared (workspace dep) и падает с ошибкой
# "package.json must be under apps/desktop/" — он не позволяет упаковывать
# файлы вне корня приложения.
#
# Hoisted-режим раскладывает workspace deps реальными файлами в node_modules,
# electron-builder собирает их корректно. Корень монорепо остаётся isolated.
node-linker=hoisted
